# ─────────────────────────────────────────────────────────────
# cod-analysis — credenciales (copiá este archivo a .env y rellená)
# NO commitear .env
# ─────────────────────────────────────────────────────────────

# Login de Dropi (tienda COD — instancia Chile app.dropi.cl)
DROPI_EMAIL=
DROPI_PASSWORD=

# Meta Ads API — CUENTA DE LA TIENDA COD (NO la de ISYRA)
META_ACCESS_TOKEN_COD=
META_AD_ACCOUNT_ID_COD=act_XXXXXXXXXXXX

# Opcional: refresh automático del token Meta (si tenés la app)
META_APP_ID_COD=
META_APP_SECRET_COD=

# Patrón para extraer el identificador de producto del nombre de campaña Meta.
# Regex con UN grupo de captura llamado (?P<key>...). Ejemplos:
#   PROD_(?P<key>[A-Z0-9-]+) \|        -> "PROD_ABRIGO-01 | CBO" => ABRIGO-01
#   \[(?P<key>[^\]]+)\]                -> "[ABRIGO-TERMICO] CBO"  => ABRIGO-TERMICO
META_CAMPAIGN_PRODUCT_REGEX=

# Shopify de la tienda COD (Noxa Store — distinta de ISYRA)
SHOPIFY_STORE_COD=xxxxx.myshopify.com
SHOPIFY_ACCESS_TOKEN_COD=
SHOPIFY_API_VERSION=2024-10

# ── Gmail IMAP (lectura del reporte programado de Ads Manager) ──
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=
GMAIL_REPORT_SUBJECT=COD - Spend diario por campaña
GMAIL_REPORT_SENDER=facebookmail.com

# Puerto del server Flask local
PORT=5057
